---

<section class="features" id="servicios">
  <div class="container">
    <div class="section-head">
      <span class="section-head__tag" data-reveal>Lo que hacemos</span>
      <h2 class="section-head__title" data-reveal>Todo lo que necesita<br />tu empresa para escalar.</h2>
      <p class="section-head__sub" data-reveal>No hacemos "de todo". Hacemos exactamente lo que tu negocio necesita para crecer, con tecnología real y resultados medibles.</p>
    </div>

    <div class="features__grid">
      {services.map((s) => (
        <article class="feat" data-reveal>
          <div class="feat__icon-wrap">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
              <defs>
                <radialGradient id={s.svgId} cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color={s.gradFrom} stop-opacity=".9"/>
                  <stop offset="100%" stop-color={s.gradTo} stop-opacity=".5"/>
                </radialGradient>
              </defs>
              <circle cx="28" cy="28" r="28" fill={`url(#${s.svgId})`}/>
              <Fragment set:html={s.iconBody} />
            </svg>
          </div>
          <h3 class="feat__title">{s.title}</h3>
          <p class="feat__desc">{s.desc}</p>
          <div class="feat__tags">
            {s.tags.map(t => <span>{t}</span>)}
          </div>
          <a href="#contacto" class="feat__link">Saber más <i data-lucide="arrow-right"></i></a>
        </article>
      ))}
    </div>
  </div>
</section>