---
// src/components/Hero.astro
---

<section class="hero" id="inicio">
  <div class="hero__glow hero__glow--1" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--2" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--3" aria-hidden="true"></div>

  <div class="container hero__inner">

    <div class="hero__text">
      <div class="badge" data-reveal>
        <span class="badge__dot"></span>
        Automatización con IA para negocios reales
      </div>

      <h1 class="hero__title" data-reveal>
        Tecnología que<br />hace crecer tu<br />
        <span class="gradient-text">negocio.</span>
      </h1>

      <p class="hero__sub" data-reveal>
        Desarrollamos software a medida, automatizamos procesos e implementamos
        inteligencia artificial para que tu empresa trabaje más inteligente, no más duro.
      </p>

      <div class="hero__actions" data-reveal>
        <a href="#contacto" class="btn btn--primary btn--lg">
          Empezar ahora
          <i data-lucide="arrow-right"></i>
        </a>
        <!-- <a href="#servicios" class="btn btn--outline btn--lg">
          <i data-lucide="play-circle"></i>
          Ver qué hacemos
        </a> -->
      </div>

      <div class="hero__stats" data-reveal>
        <div class="stat">
          <span class="stat__num">+50</span>
          <span class="stat__lbl">Proyectos entregados</span>
        </div>
        <div class="stat__sep"></div>
        <div class="stat">
          <span class="stat__num">3x</span>
          <span class="stat__lbl">Más rápido que in-house</span>
        </div>
        <div class="stat__sep"></div>
        <div class="stat">
          <span class="stat__num">98%</span>
          <span class="stat__lbl">Clientes satisfechos</span>
        </div>
      </div>
    </div>

    <div class="hero__visual" data-reveal>
      <div class="platform-base" aria-hidden="true">
        <div class="platform-base__shine"></div>
      </div>

      <div class="mockup">
        <div class="mockup__chrome">
          <div class="mockup__dots">
            <span class="dot dot--r"></span>
            <span class="dot dot--y"></span>
            <span class="dot dot--g"></span>
          </div>
          <div class="mockup__url">
            <i data-lucide="lock"></i>
            app.vaktic.io/dashboard
          </div>
        </div>
        <div class="mockup__body">
          <div class="dash">
            <aside class="dash__sidebar">
              <div class="dash__nav-item dash__nav-item--active"><i data-lucide="layout-dashboard"></i></div>
              <div class="dash__nav-item"><i data-lucide="git-branch"></i></div>
              <div class="dash__nav-item"><i data-lucide="bar-chart-3"></i></div>
              <div class="dash__nav-item"><i data-lucide="users"></i></div>
              <div class="dash__nav-item"><i data-lucide="bot"></i></div>
              <div class="dash__nav-item"><i data-lucide="settings"></i></div>
            </aside>
            <div class="dash__main">
              <div class="dash__topbar">
                <span class="dash__page-title">Panel de Control</span>
                <span class="dash__live"><span class="live-dot"></span>En vivo</span>
              </div>
              <div class="dash__kpis">
                <div class="kpi">
                  <span class="kpi__lbl">Flujos activos</span>
                  <span class="kpi__val">1,284</span>
                  <span class="kpi__up"><i data-lucide="trending-up"></i>+12%</span>
                </div>
                <div class="kpi">
                  <span class="kpi__lbl">Tasa de éxito</span>
                  <span class="kpi__val">98.7%</span>
                  <span class="kpi__up"><i data-lucide="trending-up"></i>+0.3%</span>
                </div>
                <div class="kpi">
                  <span class="kpi__lbl">Tiempo ahorrado</span>
                  <span class="kpi__val">24h/sem</span>
                  <span class="kpi__down"><i data-lucide="trending-down"></i>-40%</span>
                </div>
              </div>
              <div class="dash__chart">
                <div class="dash__chart-label">Automatizaciones ejecutadas — Últimos 30 días</div>
                <svg class="chart-svg" viewBox="0 0 420 80" preserveAspectRatio="none">
                  <defs>
                    <linearGradient id="g1" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#22d3ee" stop-opacity=".5"/>
                      <stop offset="100%" stop-color="#22d3ee" stop-opacity="0"/>
                    </linearGradient>
                    <linearGradient id="g2" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#4ade80" stop-opacity=".4"/>
                      <stop offset="100%" stop-color="#4ade80" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <path d="M0,72 C40,64 80,32 130,38 C180,44 210,14 260,20 C310,26 360,8 420,10 L420,80 L0,80Z" fill="url(#g1)"/>
                  <path d="M0,72 C40,64 80,32 130,38 C180,44 210,14 260,20 C310,26 360,8 420,10" fill="none" stroke="#22d3ee" stroke-width="2.5"/>
                  <path d="M0,80 C40,76 80,62 130,56 C180,50 220,40 260,44 C310,48 360,28 420,30 L420,80 L0,80Z" fill="url(#g2)"/>
                  <path d="M0,80 C40,76 80,62 130,56 C180,50 220,40 260,44 C310,48 360,28 420,30" fill="none" stroke="#4ade80" stroke-width="1.8"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="float-card float-card--tl">
        <div class="float-card__icon float-card__icon--green"><i data-lucide="trending-up"></i></div>
        <div>
          <span class="float-card__title">Ventas automatizadas</span>
          <span class="float-card__val">+34% este mes</span>
        </div>
      </div>

      <div class="float-card float-card--br">
        <div class="float-card__icon float-card__icon--blue"><i data-lucide="bot"></i></div>
        <div>
          <span class="float-card__title">Entrega en tiempo récord</span>
          <span class="float-card__val">MVP en 3 semanas</span>
        </div>
      </div>

      <!-- <div class="float-card float-card--br">
        <div class="float-card__icon float-card__icon--blue"><i data-lucide="bot"></i></div>
        <div>
          <span class="float-card__title">IA activa 24/7</span>
          <span class="float-card__val">Respondiendo clientes</span>
        </div>
      </div> -->

      <div class="float-donut">
        <svg viewBox="0 0 80 80" width="74" height="74">
          <circle cx="40" cy="40" r="26" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="11"/>
          <circle cx="40" cy="40" r="26" fill="none" stroke="#22d3ee" stroke-width="11" stroke-dasharray="82 82" stroke-dashoffset="20" stroke-linecap="round"/>
          <circle cx="40" cy="40" r="26" fill="none" stroke="#4ade80" stroke-width="11" stroke-dasharray="40 124" stroke-dashoffset="-62" stroke-linecap="round"/>
          <circle cx="40" cy="40" r="26" fill="none" stroke="#8b5cf6" stroke-width="11" stroke-dasharray="24 140" stroke-dashoffset="-102" stroke-linecap="round"/>
          <text x="40" y="44" text-anchor="middle" fill="white" font-size="11" font-weight="700" font-family="Plus Jakarta Sans,sans-serif">68%</text>
        </svg>
        <span>Eficiencia</span>
      </div>
    </div>
  </div>
</section>